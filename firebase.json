{
  "hosting": {
    "public": "app/static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/chat",
        "destination": "https://transit-flow-backend-4dcycqsk3q-uc.a.run.app/chat"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
