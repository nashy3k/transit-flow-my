{
  "hosting": {
    "public": "app/static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/chat",
        "run": {
          "serviceId": "transit-flow-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/config",
        "run": {
          "serviceId": "transit-flow-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/stats",
        "run": {
          "serviceId": "transit-flow-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "run": {
          "serviceId": "transit-flow-backend",
          "region": "us-central1"
        }
      }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
